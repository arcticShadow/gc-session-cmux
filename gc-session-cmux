#!/usr/bin/env bash
# gc-session-cmux — cmux (macOS terminal) session provider for Gas City.
#
# Implements the exec session provider protocol:
# https://docs.gascityhall.com/reference/exec-session-provider
#
# Workspace model: ONE cmux workspace per "rig". Sessions within the same rig
# share a workspace. Each session name like "gastown.mayor" maps to workspace
# "gc-gastown". Sessions without dots get their own workspace.
#
# Surface model (MVP): one default surface per workspace, shared by all rig
# sessions. Future: surface-per-session via cmux splits.
#
# Dependencies: cmux CLI, jq, bash
#
# Usage:
#   GC_SESSION=exec:/path/to/gc-session-cmux gc start <city>
#   GC_SESSION=exec:gc-session-cmux gc start <city>  # if on PATH

set -euo pipefail

op="${1:?missing operation}"
session_name="${2:-}"
shift 2 || true

# ── State directory ──
# Honor GC_EXEC_STATE_DIR per spec; otherwise default under $TMPDIR.
STATE_DIR="${GC_EXEC_STATE_DIR:-${TMPDIR:-/tmp}/gc-session-cmux}"
mkdir -p "$STATE_DIR"
STATE_FILE="$STATE_DIR/workspaces.json"
[ -f "$STATE_FILE" ] || echo '{"version":1,"workspaces":{}}' > "$STATE_FILE"

# ── Workspace key helpers ──
# "gastown.mayor"  → "gastown"
# "gastown"        → "gastown"
# "my-agent"       → "my-agent"
_derive_workspace_key() {
    _name="$1"
    if [[ "$_name" =~ \. ]]; then
        echo "${_name%%.*}"
    else
        echo "$_name"
    fi
}

# "gastown" → "gc-gastown"  (prefixed to avoid collisions with user workspaces)
_mk_workspace_name() {
    echo "gc-$1"
}

# ── CMUX binary detection ──
# cmux ships inside the macOS .app bundle. Auto-detect that path, or fall
# back to PATH lookup. Override via GC_CMUX_BIN.
CMUX_BIN="${GC_CMUX_BIN:-$(command -v cmux 2>/dev/null || echo /Applications/cmux.app/Contents/Resources/bin/cmux)}"

# Per spec, ops must remain idempotent and degrade gracefully when their backend
# is unreachable. We split cmux availability into two checks:
#
#   _cmux_available  — quiet predicate; returns 0/1 without printing/exiting.
#                      Use in ops that can degrade (stop, interrupt, nudge,
#                      is-running, list-running).
#
#   _cmux_require    — exits 1 with a helpful message. Use in ops that
#                      cannot proceed without cmux (start, attach, peek).
#
# File-only ops (set-meta/get-meta/remove-meta/get-last-activity) bypass
# cmux entirely.
_cmux_available() {
    [ -x "$CMUX_BIN" ] && "$CMUX_BIN" ping >/dev/null 2>&1
}

_cmux_require() {
    if [ ! -x "$CMUX_BIN" ]; then
        echo "gc-session-cmux: cmux binary not found at $CMUX_BIN" >&2
        echo "  Install cmux from https://cmux.com or set GC_CMUX_BIN" >&2
        exit 1
    fi
    if ! "$CMUX_BIN" ping >/dev/null 2>&1; then
        echo "gc-session-cmux: cmux is not responding" >&2
        echo "  Ensure cmux.app is running and the socket is accessible." >&2
        echo "  If you use socket authentication, set CMUX_SOCKET_MODE=allowAll" >&2
        echo "  in cmux Settings > Advanced, or provide --password / CMUX_SOCKET_PASSWORD." >&2
        exit 1
    fi
}

# ── CMUX helpers ──

_cmux() {
    "$CMUX_BIN" "$@" 2>/dev/null
}

_find_workspace() {
    _ws_name="$1"
    _json=$(_cmux list-workspaces --json)
    [ -z "$_json" ] && return 1
    # cmux list-workspaces --json returns {"window_ref":...,"workspaces":[...]}
    # or in some versions a plain array.  Handle both.
    echo "$_json" | jq --arg name "$_ws_name" -r '
        (.workspaces // .) as $list |
        if ($list | type) == "array" then
            $list[] | select(.title == $name) | {name:.title,ref:(.ref // .id // ""),uuid:(.uuid // .id // "")}
        elif ($list | type) == "object" then
            if $list.title == $name then {name:$list.title,ref:($list.ref // $list.id // ""),uuid:($list.uuid // $list.id // "")} else empty end
        else empty end
    '
}

_create_workspace() {
    _ws_name="$1"
    _cwd="${2:-}"
    _extra_args=()
    [ -n "$_cwd" ] && _extra_args+=("--cwd" "$_cwd")
    _cmux new-workspace --name "$_ws_name" --focus false "${_extra_args[@]}"
}

_load_workspace_from_state() {
    _key="$1"
    jq --arg key "$_key" -r '.workspaces[$key] // empty' "$STATE_FILE" 2>/dev/null
}

_save_workspace_to_state() {
    _key="$1"
    _info="$2"
    _tmp=$(mktemp)
    jq --arg key "$_key" --argjson info "$_info" '.workspaces[$key] = $info' "$STATE_FILE" > "$_tmp" && mv "$_tmp" "$STATE_FILE"
}

# Best-effort: write workspace UUID as metadata to any gc:session bead matching this rig.
_sync_bead() {
    _key="$1"
    _uuid="$2"
    command -v gc >/dev/null 2>&1 || return 0

    _beads=$(gc bd list --label gc:session --json --limit 50 2>/dev/null) || return 0
    [ -z "$_beads" ] && return 0

    echo "$_beads" | jq --arg key "$_key" -r '.[] | select(.metadata.session_name | startswith($key + "__") or . == $key) | .id' | while read -r _bead_id; do
        [ -z "$_bead_id" ] && continue
        gc bd update "$_bead_id" --set-metadata "gc.rig_workspace_uuid=$_uuid" 2>/dev/null || true
        gc bd update "$_bead_id" --set-metadata "gc.rig_workspace_name=$_key" 2>/dev/null || true
    done
}

# Wrapper-file path for a session — wrappers are the canonical
# "this session has been started, not yet stopped" marker on disk.
_wrapper_path() {
    echo "$STATE_DIR/${1}.wrapper.sh"
}

# Returns 0 if the session has a wrapper file, cmux is reachable, and the
# session's workspace exists in cmux. Used by is-running and process-alive.
_session_appears_live() {
    _sal_name="$1"
    [ -f "$(_wrapper_path "$_sal_name")" ] || return 1
    _cmux_available || return 1
    _sal_ws_key=$(_derive_workspace_key "$_sal_name")
    _sal_ws_name=$(_mk_workspace_name "$_sal_ws_key")
    _find_workspace "$_sal_ws_name" >/dev/null 2>&1 || return 1
}

# ── Operations ──

case "$op" in
  start)
    if [ -z "$session_name" ]; then
        echo "start: missing session name" >&2
        exit 1
    fi
    _cmux_require

    config=$(cat)
    work_dir=$(echo "$config" | jq -r '.work_dir // empty')
    cmd=$(echo "$config" | jq -r '.command // empty')
    env_json=$(echo "$config" | jq -r '.env // {} | to_entries[] | "export \"\(.key)=\(.value)\""' 2>/dev/null || true)
    pre_start=$(echo "$config" | jq -r '.pre_start // [] | .[]' 2>/dev/null || true)
    session_setup=$(echo "$config" | jq -r '.session_setup // [] | .[]' 2>/dev/null || true)
    session_setup_script=$(echo "$config" | jq -r '.session_setup_script // empty' 2>/dev/null || true)
    nudge_text=$(echo "$config" | jq -r '.nudge // empty')
    # lifecycle: "one_shot" hints the command exits after handling its prompt.
    # We don't need to alter behavior for cmux — the workspace persists either
    # way — but we record it so is-running can avoid restart loops if needed.
    lifecycle=$(echo "$config" | jq -r '.lifecycle // empty')

    ws_key=$(_derive_workspace_key "$session_name")
    ws_name=$(_mk_workspace_name "$ws_key")

    # pre_start: run setup on controller filesystem before session creation.
    # Per spec, per-command failure is non-fatal — warn on stderr, don't abort.
    if [ -n "$pre_start" ]; then
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            (sh -c "$line") || echo "pre_start warning: $line" >&2
        done <<< "$pre_start"
    fi

    # Build wrapper script BEFORE touching the workspace so we can launch it
    # via cmux's --command (live shell from the start). This avoids the race
    # where cmux auto-closes an empty workspace before 'send' fires, and the
    # dead-surface problem where 'send' targets a closed pty.
    wrapper=$(_wrapper_path "$session_name")
    {
        echo '#!/bin/bash'
        echo 'set -euo pipefail'
        if [ -n "$env_json" ]; then
            while IFS= read -r line; do
                [ -n "$line" ] && echo "$line"
            done <<< "$env_json"
        fi
        if [ -n "$work_dir" ]; then
            echo "cd \"$work_dir\""
        fi
        # session_setup runs inside the session environment. Per spec these
        # are non-fatal (warn but continue) — wrap each in a continuation.
        if [ -n "$session_setup" ]; then
            while IFS= read -r line; do
                [ -z "$line" ] && continue
                echo "$line || echo 'session_setup warning: $line' >&2"
            done <<< "$session_setup"
        fi
        if [ -n "$session_setup_script" ] && [ -f "$session_setup_script" ]; then
            echo "bash '$session_setup_script' || echo 'session_setup_script warning' >&2"
        fi
        if [ -n "$cmd" ]; then
            echo "exec $cmd"
        else
            echo 'exec "$SHELL"'
        fi
    } > "$wrapper"
    chmod +x "$wrapper"

    # Record lifecycle if provided — informational for is-running.
    if [ -n "$lifecycle" ]; then
        echo -n "$lifecycle" > "$STATE_DIR/${session_name}.lifecycle"
    else
        rm -f "$STATE_DIR/${session_name}.lifecycle"
    fi

    # Check if a live workspace already exists for this key.
    _existing_info=$(_load_workspace_from_state "$ws_key")
    _workspace_live=false
    if [ -n "$_existing_info" ]; then
        _existing_ref=$(echo "$_existing_info" | jq -r '.ref // .uuid // empty')
        if [ -n "$_existing_ref" ] && _find_workspace "$ws_name" >/dev/null 2>&1; then
            _workspace_live=true
        fi
    fi

    if [ "$_workspace_live" = "true" ]; then
        # Existing workspace: respawn its surface directly with the wrapper command.
        # Handles the case where the previous command exited (killing the pty).
        ws_ref="$_existing_ref"
        if ! _cmux respawn-pane --workspace "$ws_ref" --command "bash '$wrapper'" 2>/dev/null; then
            # respawn-pane failed (e.g. no pane ref available) — fall back to
            # creating a fresh surface and sending.
            _cmux new-surface --type terminal --workspace "$ws_ref" --focus false 2>/dev/null || true
            sleep 0.5
            _cmux send --workspace "$ws_ref" "bash '$wrapper'\\n" 2>/dev/null || true
        fi
    else
        # New (or lost) workspace: create with the wrapper as the launch command
        # so cmux starts the process immediately and won't auto-close.
        _cmux new-workspace --name "$ws_name" --command "bash '$wrapper'" \
            ${work_dir:+--cwd "$work_dir"} --focus false 2>/dev/null || {
            echo "Failed to create cmux workspace '$ws_name'" >&2
            exit 1
        }
        _new_info=$(_find_workspace "$ws_name") || {
            echo "Created workspace but could not find it in list" >&2
            exit 1
        }
        _new_info=$(echo "$_new_info" | jq --arg key "$ws_key" '{key: $key} + .')
        _save_workspace_to_state "$ws_key" "$_new_info"
        ws_ref=$(echo "$_new_info" | jq -r '.ref // .uuid // empty')
        _uuid=$(echo "$_new_info" | jq -r '.uuid // .ref // empty')
        [ -n "$_uuid" ] && _sync_bead "$ws_key" "$_uuid"
    fi

    if [ -z "$ws_ref" ]; then
        echo "Workspace has no ref/uuid" >&2
        exit 1
    fi

    # Handle nudge text if provided
    if [ -n "$nudge_text" ]; then
        sleep 0.5
        escaped=$(printf '%s' "$nudge_text" | sed 's/\\n/\\n/g; s/\n/\\n/g')
        _cmux send --workspace "$ws_ref" "$escaped\\n" 2>/dev/null || true
    fi
    ;;

  stop)
    # Per spec: stop must succeed (exit 0) even if the session doesn't exist.
    # Clean up local wrapper unconditionally; best-effort Ctrl+C if cmux is up.
    rm -f "$(_wrapper_path "$session_name")"
    rm -f "$STATE_DIR/${session_name}.lifecycle"

    if [ -n "$session_name" ] && _cmux_available; then
        ws_key=$(_derive_workspace_key "$session_name")
        ws_info=$(_load_workspace_from_state "$ws_key") || ws_info=""
        if [ -n "$ws_info" ]; then
            ws_ref=$(echo "$ws_info" | jq -r '.ref // .uuid // empty')
            [ -n "$ws_ref" ] && _cmux send --workspace "$ws_ref" $'\x03' 2>/dev/null || true
        fi

        # Close the workspace if this was the last session in the rig.
        # The wrapper file for this session was already removed above, so any
        # remaining .wrapper.sh files for the same ws_key belong to siblings.
        _sibling_running=false
        for _f in "$STATE_DIR"/*.wrapper.sh; do
            [ -f "$_f" ] || continue
            _sname=$(basename "$_f" .wrapper.sh)
            if [ "$(_derive_workspace_key "$_sname")" = "$ws_key" ]; then
                _sibling_running=true
                break
            fi
        done

        if [ "$_sibling_running" = "false" ] && [ -n "${ws_info:-}" ]; then
            _close_ref=$(echo "$ws_info" | jq -r '.ref // .uuid // empty')
            [ -n "$_close_ref" ] && _cmux close-workspace --workspace "$_close_ref" 2>/dev/null || true
            _tmp=$(mktemp)
            jq --arg key "$ws_key" 'del(.workspaces[$key])' "$STATE_FILE" > "$_tmp" && mv "$_tmp" "$STATE_FILE"
        fi
    fi
    exit 0
    ;;

  interrupt)
    # Per spec: best-effort; exit 0 even if session doesn't exist.
    [ -z "$session_name" ] && exit 0
    if _cmux_available; then
        ws_key=$(_derive_workspace_key "$session_name")
        ws_info=$(_load_workspace_from_state "$ws_key") || ws_info=""
        if [ -n "$ws_info" ]; then
            ws_ref=$(echo "$ws_info" | jq -r '.ref // .uuid // empty')
            [ -n "$ws_ref" ] && _cmux send --workspace "$ws_ref" $'\x03' 2>/dev/null || true
        fi
    fi
    exit 0
    ;;

  is-running)
    # Per spec: stdout is "true" or "false". A graceful "false" when cmux is
    # unreachable is correct — no session can be running without cmux.
    if [ -z "$session_name" ]; then
        echo "false"
        exit 0
    fi
    if _session_appears_live "$session_name"; then
        # Repair missing state so subsequent operations work.
        ws_key=$(_derive_workspace_key "$session_name")
        ws_name=$(_mk_workspace_name "$ws_key")
        if [ -z "$(_load_workspace_from_state "$ws_key")" ]; then
            _recovered=$(_find_workspace "$ws_name")
            _recovered=$(echo "$_recovered" | jq --arg key "$ws_key" '{key: $key} + .')
            _save_workspace_to_state "$ws_key" "$_recovered"
        fi
        echo "true"
    else
        echo "false"
    fi
    ;;

  attach)
    if [ -z "$session_name" ]; then
        echo "attach: missing session name" >&2
        exit 1
    fi
    _cmux_require

    ws_key=$(_derive_workspace_key "$session_name")
    ws_name=$(_mk_workspace_name "$ws_key")

    # Always validate against live cmux state — cached refs go stale when workspaces are closed.
    ws_info=$(_find_workspace "$ws_name") || ws_info=""

    if [ -z "$ws_info" ]; then
        # Workspace is gone — reopen it. Best-effort: restore cwd from the wrapper.
        _attach_cwd=""
        _wrapper=$(_wrapper_path "$session_name")
        if [ -f "$_wrapper" ]; then
            _attach_cwd=$(grep '^cd ' "$_wrapper" | head -1 | sed 's/^cd "//;s/"$//')
        fi
        _create_workspace "$ws_name" "$_attach_cwd" || {
            echo "gc-session-cmux: failed to create cmux workspace '$ws_name'" >&2
            exit 1
        }
        ws_info=$(_find_workspace "$ws_name") || ws_info=""
        if [ -z "$ws_info" ]; then
            echo "gc-session-cmux: could not find workspace '$ws_name' after creation" >&2
            exit 1
        fi
        ws_info=$(echo "$ws_info" | jq --arg key "$ws_key" '{key: $key} + .')
        _save_workspace_to_state "$ws_key" "$ws_info"
    fi

    ws_ref=$(echo "$ws_info" | jq -r '.ref // .uuid // empty')
    if [ -z "$ws_ref" ]; then
        echo "gc-session-cmux: workspace '$ws_name' has no ref/uuid" >&2
        exit 1
    fi

    _cmux select-workspace "$ws_ref" 2>/dev/null || true
    echo "CMUX workspace: $ws_name (ref: $ws_ref)"
    echo "Switch to the cmux window to interact."
    ;;

  process-alive)
    # Per spec: stdin contains process names, one per line; stdout is true/false.
    # File operation only — does NOT require cmux for the pgrep path.
    if [ -z "$session_name" ]; then
        echo "false"
        exit 0
    fi

    process_names=()
    # `read -r` returns non-zero when it reads a partial final line (no
    # trailing newline). Consume that too so callers don't have to ensure a
    # trailing newline.
    while IFS= read -r pname || [ -n "$pname" ]; do
        [ -n "$pname" ] && process_names+=("$pname")
    done

    # Gate ALL process-alive paths on the session actually being live in
    # cmux. Without this, `pgrep -f node|claude` matches Cursor extensions,
    # the Claude.app helpers, MCP servers, and so on — every non-existent
    # session looks alive, which makes Gas City's reconciler report
    # alive=true for ghost sessions. The result is either silent stuck-awake
    # beads (pre-ju-ac49 Option 1 patch) or a rollback storm (post-patch).
    # See jude ju-u015 for the trace and the symptom.
    if ! _session_appears_live "$session_name"; then
        echo "false"
        exit 0
    fi

    if [ ${#process_names[@]} -eq 0 ]; then
        # Session is live and no process names to filter on — report alive.
        echo "true"
        exit 0
    fi

    found=false
    for pname in "${process_names[@]}"; do
        if pgrep -f "$pname" >/dev/null 2>&1; then
            found=true
            break
        fi
    done

    if [ "$found" = true ]; then
        echo "true"
    else
        echo "false"
    fi
    ;;

  nudge)
    # Per spec: best-effort; exit 0 even if session doesn't exist.
    [ -z "$session_name" ] && exit 0
    msg=$(cat)
    if _cmux_available; then
        ws_key=$(_derive_workspace_key "$session_name")
        ws_info=$(_load_workspace_from_state "$ws_key") || ws_info=""
        if [ -n "$ws_info" ]; then
            ws_ref=$(echo "$ws_info" | jq -r '.ref // .uuid // empty')
            [ -n "$ws_ref" ] && _cmux send --workspace "$ws_ref" "$msg\\n" 2>/dev/null || true
        fi
    fi
    exit 0
    ;;

  set-meta)
    # File-only operation; does not require cmux.
    key="${1:?set-meta: missing key}"
    [ -z "$session_name" ] && exit 1
    value=$(cat)
    echo -n "$value" > "$STATE_DIR/${session_name}.meta.${key}"
    ;;

  get-meta)
    # File-only operation; does not require cmux.
    key="${1:?get-meta: missing key}"
    [ -z "$session_name" ] && exit 0
    meta_file="$STATE_DIR/${session_name}.meta.${key}"
    # Use an if/then block instead of `&&` so `set -e` doesn't propagate
    # the "file missing" condition into a non-zero script exit.
    if [ -f "$meta_file" ]; then
        cat "$meta_file"
    fi
    # Empty stdout = not set (per protocol).
    ;;

  remove-meta)
    # File-only operation; does not require cmux.
    key="${1:?remove-meta: missing key}"
    [ -z "$session_name" ] && exit 0
    rm -f "$STATE_DIR/${session_name}.meta.${key}"
    ;;

  peek)
    lines="${1:-0}"
    [ -z "$session_name" ] && exit 0
    # peek requires cmux to read screen contents. Per spec, return empty
    # on failure (peek's stdout is captured text; empty is a valid result).
    _cmux_available || exit 0

    ws_key=$(_derive_workspace_key "$session_name")
    ws_info=$(_load_workspace_from_state "$ws_key") || ws_info=""
    [ -z "$ws_info" ] && exit 0
    ws_ref=$(echo "$ws_info" | jq -r '.ref // .uuid // empty')
    [ -z "$ws_ref" ] && exit 0

    if [ "$lines" -gt 0 ] 2>/dev/null; then
        _cmux read-screen --workspace "$ws_ref" --scrollback --lines "$lines" 2>/dev/null || true
    else
        _cmux read-screen --workspace "$ws_ref" --scrollback 2>/dev/null || true
    fi
    ;;

  list-running)
    # Per spec: <prefix> is the second positional. After `shift 2`, the
    # original $2 is in $session_name — repurpose it as the prefix filter.
    prefix="${session_name:-}"
    # Gracefully return empty if cmux is down — empty list is a valid result.
    _cmux_available || exit 0

    json=$(_cmux list-workspaces --json 2>/dev/null) || exit 0
    [ -z "$json" ] && exit 0

    echo "$json" | jq --arg prefix "$prefix" -r '(.workspaces // .) as $list |
        if ($list | type) == "array" then $list[] elif ($list | type) == "object" then $list else empty end |
        select(.title | startswith("gc-")) |
        .title |
        ltrimstr("gc-") |
        if $prefix == "" or startswith($prefix) then . else empty end
    '
    exit 0
    ;;

  get-last-activity)
    # Per spec: empty stdout = unsupported (maps to Go zero time).
    # CMUX does not expose per-workspace activity timestamps via CLI.
    ;;

  copy-to)
    # NOT part of the spec — provider-specific extension for copy_files support.
    # Treated as a recognized op (exit 0) rather than exit 2 to avoid the
    # reconciler classifying it as "unknown" if it ever invokes it.
    src="${1:-}"
    rel_dst="${2:-}"
    [ -z "$session_name" ] || [ -z "$src" ] && exit 0

    wrapper=$(_wrapper_path "$session_name")
    work_dir=""
    if [ -f "$wrapper" ]; then
        work_dir=$(grep '^cd ' "$wrapper" | head -1 | sed 's/^cd "//;s/"$//')
    fi
    [ -z "$work_dir" ] && exit 0

    dst="$work_dir"
    [ -n "$rel_dst" ] && dst="$work_dir/$rel_dst"

    if [ -d "$src" ]; then
        mkdir -p "$dst"
        cp -r "$src/." "$dst/" 2>/dev/null || true
    elif [ -f "$src" ]; then
        mkdir -p "$(dirname "$dst")"
        cp "$src" "$dst" 2>/dev/null || true
    fi
    ;;

  *)
    # Per spec: unknown operation → exit 2 (treated as forward-compatible no-op).
    exit 2
    ;;
esac
